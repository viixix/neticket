{
  "name": "@neticket/monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Neticket ticketing system monorepo",
  "scripts": {
    "prepare": "husky",
    "dev:show": "pnpm --filter @neticket/show start:dev",
    "dev:booking": "pnpm --filter @neticket/booking start:dev",
    "dev:queue": "pnpm infra:queue && pnpm --filter @neticket/queue start:dev",
    "dev:frontend": "pnpm --filter frontend dev",
    "build:show": "pnpm --filter @neticket/show build",
    "build:booking": "pnpm --filter @neticket/booking build",
    "build:queue": "pnpm --filter @neticket/queue build",
    "build:frontend": "pnpm --filter frontend build",
    "infra:queue": "pnpm --filter @neticket/queue infra:up",
    "infra:queue:down": "pnpm --filter @neticket/queue infra:down",
    "lint:show": "pnpm --filter @neticket/show lint",
    "lint:booking": "pnpm --filter @neticket/booking lint",
    "lint:queue": "pnpm --filter @neticket/queue lint",
    "lint:frontend": "pnpm --filter frontend lint",
    "preinstall": "npx only-allow pnpm"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7"
  },
  "lint-staged": {
    "backend/show/**/*.{ts,tsx,js,jsx}": [
      "pnpm --filter @neticket/show lint"
    ],
    "backend/booking/**/*.{ts,tsx,js,jsx}": [
      "pnpm --filter @neticket/booking lint"
    ],
    "queue/**/*.{ts,tsx,js,jsx}": [
      "pnpm --filter @neticket/queue lint"
    ],
    "frontend/**/*.{ts,tsx,js,jsx}": [
      "pnpm --filter frontend lint"
    ]
  }
}
